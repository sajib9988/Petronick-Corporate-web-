
// ======================
// CONTACT
// ======================
model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String   @db.VarChar(255)
  phone     String?
  message   String
  createdAt DateTime @default(now())

  @@index([email])
  @@map("contact")
}

// ======================
// PROMOTION AGENT
// ======================
model PromotionAgent {
  id            String      @id @default(cuid())
  fullName      String
  email         String
  phone         String
  location      String
  experience    String
  focus         String
  message       String
  status        AgentStatus @default(PENDING)
  businessUnits BusinessUnit[]
  createdAt     DateTime    @default(now())

  @@map("promotion_agent")
}

model BusinessUnit {
  id      String         @id @default(cuid())
  name    String
  agentId String
  agent   PromotionAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("business_unit")
}

// ======================
// COMPANY
// ======================
model Company {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String
  logo         String
  website      String?
  order        Int      @default(0)
  isVisible    Boolean  @default(true)
  revenueStage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("company")
}

// ======================
// CMS: PAGE
// ======================
model Page {
  id        String    @id @default(cuid())
  slug      String    @unique
  title     String
  sections  Section[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("page")
}

// ======================
// CMS: SECTION
// ======================
model Section {
  id          String      @id @default(cuid())
  pageId      String
  sectionType SectionType
  content     Json
  image       String?
   sortOrder   Int         @default(0) @map("order") 
  isVisible   Boolean     @default(true)
  page        Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([pageId, sortOrder])
  @@map("section")
}